<UserControl x:Class="ActEditor.Core.WPF.EditorControls.ActSelectorComponents.FrameTextBoxSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ActEditor.Core.WPF.EditorControls.ActSelectorComponents" xmlns:GenericControls="clr-namespace:ActEditor.Core.WPF.GenericControls"
			 mc:Ignorable="d">
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition />
			<ColumnDefinition Width="auto" />
		</Grid.ColumnDefinitions>
		<Border Margin="3 0 0 0" BorderBrush="Transparent" Name="_borderFrameIndex" BorderThickness="1" VerticalAlignment="Center" CornerRadius="1" >
			<GenericControls:ClickSelectTextBox x:Name="_tbFrameIndex" TextChanged="_tbFrameIndex_TextChanged" BorderThickness="0" Text="0" TextAlignment="Right" VerticalAlignment="Center" />
		</Border>
		<TextBox ToolTipService.ShowDuration="1000000" Background="Transparent" Grid.Column="1" BorderThickness="0" IsHitTestVisible="False" Name="_labelFrameIndex" Text="/ 0 frames" Padding="0" VerticalAlignment="Center">
			<TextBox.ToolTip>
				The index of the frame in the selected action. This index is 0 based.
			</TextBox.ToolTip>
		</TextBox>
	</Grid>
</UserControl>
