<UserControl x:Class="ActEditor.Core.WPF.EditorControls.CompactActIndexSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Opacity="0.7" 
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:Styles="clr-namespace:TokeiLibrary.WPF.Styles;assembly=TokeiLibrary" FontSize="10"
             xmlns:GenericControls1="clr-namespace:ActEditor.Core.WPF.GenericControls" xmlns:actselectorcomponents="clr-namespace:ActEditor.Core.WPF.EditorControls.ActSelectorComponents" mc:Ignorable="d"
             Background="{StaticResource TabItemBackground}" Foreground="{StaticResource TextForeground}">
    <Grid Background="{StaticResource TabItemBackground}" >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
		<actselectorcomponents:ActionDirectionalControl x:Name="_directionalControl" VerticalAlignment="Bottom" />
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <TextBlock ToolTipService.ShowDuration="1000000"  VerticalAlignment="Center" Text="Animation" TextAlignment="Center" Margin="3" TextWrapping="Wrap" >
                                <TextBlock.ToolTip>
                                    <TextBlock TextAlignment="Left">
                                        Animations are not part of the Act structure. This simply makes the
                                    <LineBreak />
                                        action index selection easier.
                                    </TextBlock>
                                </TextBlock.ToolTip>
                            </TextBlock>
            <TextBlock Text="Action" Grid.Row="1" VerticalAlignment="Center" Margin="3" TextAlignment="Center" TextWrapping="Wrap" />
        </Grid>
        <Grid Grid.Column="2" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <ComboBox Grid.Row="0" FontSize="12" VerticalAlignment="Center" Name="_comboBoxAnimationIndex" Width="80" HorizontalAlignment="Left" Margin="1" />
            <ComboBox Grid.Row="1" FontSize="12" VerticalAlignment="Center" Name="_comboBoxActionIndex" Width="80" HorizontalAlignment="Left" Margin="1" />
        </Grid>
		<actselectorcomponents:FrameScrollBar x:Name="_sbFrameIndex" Grid.ColumnSpan="2" Grid.Row="1" Margin="0 1 0 1" />
		<actselectorcomponents:FrameTextBoxSelector Grid.Row="1" Grid.Column="2" x:Name="_frameTbSelect" />
	</Grid>
</UserControl>
